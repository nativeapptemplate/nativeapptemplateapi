<%= turbo_frame_tag "tb_completed_item_tags" do %>
  <%= turbo_stream.update("tb_stream_completed_item_tags") do %>
    <%= render "completings_normal_layout",
      shop: @shop,
      completed_item_tags: @completed_item_tags,
      pagy: @pagy,
      type: @type,
      item_tag_id: @item_tag_id %>
  <% end %>
  <%= turbo_stream.update("tb_stream_completed_next_page_link") do %>
    <%= link_to "next page",
      completings_display_shop_item_tags_path(@shop, type: @type, item_tag_id: @item_tag_id, page: @pagy.next),
      data: {
        turbo_frame: "tb_completed_item_tags",
        click_repeatedly_target: "clickable"
      },
      hidden: true %>

    <%= link_to "current page",
      completings_display_shop_item_tags_path(@shop, type: @type, item_tag_id: @item_tag_id, page: @pagy.page),
      data: {
        turbo_frame: "tb_completed_item_tags"
      },
      class: "js-current-page-link",
      hidden: true %>
  <% end %>
  <%= turbo_stream.update("tb_stream_latest_item_tag") do %>
    <%= render "display/shops/latest_item_tag",
      item_tag: @shop.latest_completed_item_tag,
      type: @type,
      item_tag_id: @item_tag_id %>
  <% end %>
<% end %>
